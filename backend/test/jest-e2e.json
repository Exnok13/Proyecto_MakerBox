{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "setupFiles": ["<rootDir>/setup-env.ts"],
  "coverageDirectory": "../coverage",
  "coverageReporters": ["text", "lcov", "clover"],
  "collectCoverageFrom": [
  "src/**/*.(t|j)s",
  "!src/main.ts",
  "!src/**/*(module|dto|entity).ts"
]
}
